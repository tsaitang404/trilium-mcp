# Trilium 服务地址
TRILIUM_URL=http://host.docker.internal:8080

# ETAPI Token（在 Trilium Options -> ETAPI 中获取）
TRILIUM_TOKEN=your_token_here

# MCP 传输模式：stdio / sse / streamable-http
TRILIUM_MCP_TRANSPORT=streamable-http

# 可选：为 MCP 单独配置 token（若不设置则使用 TRILIUM_TOKEN）
# TRILIUM_MCP_TOKEN=<optional_mcp_token>
# 可选：通过设置为 true/1/yes 来关闭 MCP 的 Bearer Token 鉴权（默认为开启，若未设置 token 则自动关闭）
# TRILIUM_MCP_AUTH_DISABLED=false
